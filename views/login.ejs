<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SOURAV — Admin Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Syne:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Syne', sans-serif; background: #020408; color: #e0eeff; }
    .orbitron { font-family: 'Orbitron', sans-serif; }
    .glow-cyan { text-shadow: 0 0 20px rgba(0,212,255,0.5); }
    .glow-violet { text-shadow: 0 0 20px rgba(123,97,255,0.5); }
    .border-cyan { border-color: rgba(0,212,255,0.2); }
    .border-cyan:hover { border-color: rgba(0,212,255,0.6); }
    input:focus { outline: none; border-color: #00D4FF !important; box-shadow: 0 0 12px rgba(0,212,255,0.2); }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md relative">
    <!-- Corner accents -->
    <div class="absolute -top-1 -left-1 w-4 h-4 border-t-2 border-l-2 border-cyan-400"></div>
    <div class="absolute -top-1 -right-1 w-4 h-4 border-t-2 border-r-2 border-violet-400"></div>
    <div class="absolute -bottom-1 -left-1 w-4 h-4 border-b-2 border-l-2 border-violet-400"></div>
    <div class="absolute -bottom-1 -right-1 w-4 h-4 border-b-2 border-r-2 border-cyan-400"></div>

    <div class="bg-[rgba(5,13,26,0.9)] border border-[rgba(0,212,255,0.15)] p-8 md:p-10">
      <div class="text-center mb-8">
        <h1 class="orbitron text-xl tracking-[0.3em] text-cyan-400 glow-cyan mb-2">◈ ADMIN ACCESS</h1>
        <p class="text-[0.65rem] tracking-[0.2em] text-[rgba(224,238,255,0.35)]">Authorized Personnel Only</p>
      </div>

      <div class="space-y-4">
        <div>
          <label class="orbitron text-[0.55rem] tracking-[0.2em] text-[rgba(224,238,255,0.5)] block mb-1.5">IDENTIFICATION</label>
          <input type="text" id="loginUser" value="Sourav"
            class="w-full bg-[rgba(255,255,255,0.03)] border border-[rgba(0,212,255,0.15)] px-4 py-3 text-sm text-[#e0eeff] transition-all duration-200">
        </div>
        <div>
          <label class="orbitron text-[0.55rem] tracking-[0.2em] text-[rgba(224,238,255,0.5)] block mb-1.5">PASSPHRASE</label>
          <input type="password" id="loginPass"
            class="w-full bg-[rgba(255,255,255,0.03)] border border-[rgba(0,212,255,0.15)] px-4 py-3 text-sm text-[#e0eeff] transition-all duration-200"
            onkeydown="if(event.key==='Enter')doLogin()">
        </div>
      </div>

      <button onclick="doLogin()"
        class="w-full mt-6 orbitron text-[0.6rem] tracking-[0.25em] uppercase py-3.5 border border-cyan-400 text-cyan-400 transition-all duration-300 hover:bg-cyan-400 hover:text-[#020408]">
        Authenticate
      </button>

      <p id="loginError" class="text-center mt-4 text-[0.6rem] text-red-400 tracking-[0.15em]"></p>
      <div class="text-center mt-5">
        <a href="/" class="text-[0.5rem] tracking-[0.2em] text-[rgba(224,238,255,0.2)] hover:text-cyan-400 transition-colors">← Back to Portfolio</a>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = '';

    async function doLogin() {
      const user = document.getElementById('loginUser').value.trim();
      const pass = document.getElementById('loginPass').value;
      const err = document.getElementById('loginError');
      try {
        const res = await fetch(API_BASE + '/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: user, password: pass })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Login failed');
        localStorage.setItem('admin_token', data.token);
        window.location.href = '/admin/dashboard';
      } catch (e) {
        err.textContent = '✕ ' + e.message;
      }
    }

    // Auto-redirect if already logged in
    (async () => {
      const token = localStorage.getItem('admin_token');
      if (token) {
        try {
          const res = await fetch(API_BASE + '/api/auth/verify', {
            headers: { 'Authorization': 'Bearer ' + token }
          });
          if (res.ok) window.location.href = '/admin/dashboard';
        } catch {}
      }
    })();
  </script>
</body>
</html>
